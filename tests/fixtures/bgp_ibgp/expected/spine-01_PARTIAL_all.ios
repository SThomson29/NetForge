

! --- section break ---

ssh server vrf default
https server vrf default
ip source interface all interface loopback0

! --- section break ---

hostname spine-01
profile default
clock timezone UTC
ntp server 10.0.0.123 minpoll 4 maxpoll 4 iburst
ntp enable
spanning-tree

! --- section break ---


! --- section break ---


! --- section break ---


! --- section break ---


! --- section break ---


! --- section break ---


! --- section break ---


interface 1/1/1
    description P2P to leaf-01
    no shutdown
    mtu 9198
    ip address 10.254.0.0/31
    ip ospf 1 area 0.0.0.0
    ip ospf network point-to-point
interface 1/1/2
    description P2P to leaf-02
    no shutdown
    mtu 9198
    ip address 10.254.0.2/31
    ip ospf 1 area 0.0.0.0
    ip ospf network point-to-point
interface 1/1/3
    description P2P to spine-02
    no shutdown
    mtu 9198
    ip address 10.254.0.4/31
    ip ospf 1 area 0.0.0.0
    ip ospf network point-to-point

! --- section break ---


! --- section break ---

interface loopback0
    description Router ID / BGP source
    ip address 10.255.0.1/32
    ip ospf 1 area 0.0.0.0

! --- section break ---


! --- section break ---

router ospf 1
    router-id 10.255.0.1
    area 0.0.0.0

! --- section break ---

# iBGP for EVPN control plane - Route Reflector

# iBGP for EVPN control plane - Route Reflector Client


