

! --- section break ---

ssh server vrf default
https server vrf default
ip source interface all interface loopback0

! --- section break ---

hostname agg-01
profile default
clock timezone Europe/London
ntp server 10.0.0.123 minpoll 4 maxpoll 4 iburst
ntp enable
spanning-tree

! --- section break ---


! --- section break ---


! --- section break ---


! --- section break ---


! --- section break ---

vlan 10
    name Prod
vlan 20
    name Mgmt

! --- section break ---


! --- section break ---


interface 1/1/1
    description LACP active LAG1 member
    no shutdown
    mtu 9198
    lag lag1
interface 1/1/2
    description LACP active LAG1 member
    no shutdown
    mtu 9198
    lag lag1
interface 1/1/3
    description LACP passive LAG2 member
    no shutdown
    mtu 9198
    lag lag2
interface 1/1/4
    description Static LAG3 member
    no shutdown
    mtu 9198
    lag lag3
interface 1/1/5
    description Static LAG3 member
    no shutdown
    mtu 9198
    lag lag3

! --- section break ---

interface lag1
    description LACP active L2 trunk
    no shutdown
    mtu 9198
    lacp mode active
    vlan trunk native 1
    vlan trunk allowed 10,20
interface lag2
    description LACP passive L2 trunk
    no shutdown
    mtu 9198
    lacp mode passive
    vlan trunk native 1
    vlan trunk allowed all
interface lag3
    description Static L3 routed LAG
    no shutdown
    mtu 9198
    ip address 10.254.2.0/31
    ip ospf 1 area 0.0.0.0
    ip ospf network point-to-point

! --- section break ---

interface loopback0
    ip address 10.255.5.1/32
    ip ospf 1 area 0.0.0.0

! --- section break ---


! --- section break ---

router ospf 1
    router-id 10.255.5.1
    area 0.0.0.0

! --- section break ---

# iBGP for EVPN control plane - Route Reflector

# iBGP for EVPN control plane - Route Reflector Client


! --- section break ---


! --- section break ---


! --- section break ---

