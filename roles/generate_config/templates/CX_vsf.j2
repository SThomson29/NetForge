{# =============================================================
   Template : CX_vsf.j2
   Role     : generate_config
   Device   : {{ inventory_hostname }}
   Platform : {{ platform | default("aoscx") }}
   Variables: vsf.enabled, vsf.members[].id,
              vsf.member.link1, vsf.member.link2
   ============================================================= #}

{% if vsf is defined and vsf.enabled | default(false) %}
{% for member in vsf.members %}
vsf member {{ member.id }}
    vsf member {{ member.id }} link 1 {{ member.link1 }}
    vsf member {{ member.id }} link 2 {{ member.link2 }}
{% endfor %}
vsf secondary-member 2
{% endif %}
